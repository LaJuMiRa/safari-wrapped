{
  "manifest_version": 3,
  "name": "Browsing Wrapped",
  "version": "0.1.0",
  "description": "Lokaler Browsing-Rückblick à la Spotify Wrapped. Alle Daten bleiben auf deinem Gerät.",
  "permissions": [
    "tabs",
    "storage",
    "webNavigation",
    "idle",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Browsing Wrapped"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
